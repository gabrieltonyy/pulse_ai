```env
# =========================================
# APPLICATION
# =========================================
APP_NAME=Pulse AI
APP_ENV=development
DEBUG=true
SECRET_KEY=change_this_in_production

# =========================================
# SERVER
# =========================================
HOST=0.0.0.0
PORT=8000

# =========================================
# DATABASE
# =========================================
DATABASE_URL=sqlite:///./pulse_ai.db

# =========================================
# DEMO MODE
# =========================================
DEMO_MODE=true
CACHE_TTL_SECONDS=900

# =========================================
# EVENT PROVIDERS
# =========================================

# Ticketmaster Discovery API
TICKETMASTER_API_KEY=

# Geoapify Places API
GEOAPIFY_API_KEY=

# OpenWeather API
OPENWEATHER_API_KEY=

# =========================================
# LLM PROVIDERS
# =========================================

# Supported values:
# none
# openai
# anthropic
# watsonx
LLM_PROVIDER=none

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# IBM watsonx.ai
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=

# =========================================
# SECURITY
# =========================================

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# Session security
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=lax

# =========================================
# LOGGING
# =========================================
LOG_LEVEL=INFO

# =========================================
# FEATURE FLAGS
# =========================================

# Enable workflow trace panel
ENABLE_WORKFLOW_TRACE=true

# Enable calendar export
ENABLE_CALENDAR_EXPORT=true

# Enable venue enrichment
ENABLE_VENUE_ENRICHMENT=true

# Enable weather enrichment
ENABLE_WEATHER_CONTEXT=true

# =========================================
# RATE LIMITING
# =========================================
SEARCH_RATE_LIMIT_PER_MINUTE=20
REDIRECT_RATE_LIMIT_PER_MINUTE=60
CALENDAR_RATE_LIMIT_PER_MINUTE=30

# =========================================
# OPTIONAL FUTURE FEATURES
# =========================================

# Redis (future)
REDIS_URL=

# PostgreSQL (future)
POSTGRES_URL=

# Sentry (future)
SENTRY_DSN=
```
